# Copy these values to apps/api/.env for local API development.

DATABASE_URL=postgres://postgres:postgres@localhost:5432/fantasy_book
PORT=3000
NODE_ENV=development
APP_PUBLIC_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

AUTH_COOKIE_NAME=fantasy_book_session
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_HOURS=24

# If SMTP_HOST or SMTP_FROM is missing, verification links are logged to the API console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Fantasy Book <no-reply@example.com>"

# Existing LLM/image providers.
API_KEY_OAUTH_ELIZA=
API_KEY_YANDEX=
PERPLEXITY_API_KEY=
